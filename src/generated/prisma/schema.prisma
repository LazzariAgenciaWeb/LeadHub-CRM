generator client {
  provider      = "prisma-client-js"
  output        = "../src/generated/prisma"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "linux-musl-arm64-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Usuários ─────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      UserRole @default(CLIENT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company   Company? @relation(fields: [companyId], references: [id])
  companyId String?

  ticketsCreated Ticket[] @relation("TicketCreatedBy")

  @@index([companyId])
}

enum UserRole {
  SUPER_ADMIN
  CLIENT
}

// ─── Empresas ─────────────────────────────────────────────────────────────────

model Company {
  id        String        @id @default(cuid())
  name      String
  slug      String        @unique
  segment   String?
  phone     String?
  email     String?
  website   String?
  logoUrl   String?
  status    CompanyStatus @default(ACTIVE)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  users             User[]
  campaigns         Campaign[]
  leads             Lead[]
  whatsappInstances WhatsappInstance[]
  messages          Message[]
  keywordRules      KeywordRule[]
  tickets           Ticket[]
  trackingLinks     TrackingLink[]
  triggerOnly       Boolean            @default(false)
}

enum CompanyStatus {
  ACTIVE
  INACTIVE
}

// ─── Campanhas ────────────────────────────────────────────────────────────────

model Campaign {
  id          String         @id @default(cuid())
  name        String
  slug        String
  description String?
  source      CampaignSource @default(OTHER)
  status      CampaignStatus @default(ACTIVE)
  budget      Float?
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId String

  leads        Lead[]
  messages     Message[]
  links        TrackingLink[]
  keywordRules KeywordRule[]

  @@unique([companyId, slug])
  @@index([companyId])
}

enum CampaignSource {
  WHATSAPP
  INSTAGRAM
  FACEBOOK
  GOOGLE
  LINK
  OTHER
}

enum CampaignStatus {
  ACTIVE
  PAUSED
  FINISHED
}

// ─── Links de Rastreio ────────────────────────────────────────────────────────

model TrackingLink {
  id            String   @id @default(cuid())
  code          String   @unique
  label         String?
  destination   String
  destType      String   @default("url")
  clicks        Int      @default(0)
  ogTitle       String?
  ogDescription String?  @db.Text
  ogImage       String?
  createdAt     DateTime @default(now())

  campaign   Campaign? @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  campaignId String?

  company   Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId String?

  leads       Lead[]
  clickEvents ClickEvent[]

  @@index([campaignId])
  @@index([companyId])
}

model ClickEvent {
  id             String       @id @default(cuid())
  trackingLink   TrackingLink @relation(fields: [trackingLinkId], references: [id], onDelete: Cascade)
  trackingLinkId String
  targetUrl      String       @db.Text
  targetLabel    String?
  createdAt      DateTime     @default(now())

  @@index([trackingLinkId])
}

// ─── Leads ────────────────────────────────────────────────────────────────────

model Lead {
  id        String     @id @default(cuid())
  name      String?
  phone     String
  email     String?
  source    String?
  status    LeadStatus @default(NEW)
  notes     String?    @db.Text
  value     Float?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId String

  campaign   Campaign? @relation(fields: [campaignId], references: [id])
  campaignId String?

  trackingLink   TrackingLink? @relation(fields: [trackingLinkId], references: [id])
  trackingLinkId String?

  messages Message[]

  @@index([companyId])
  @@index([campaignId])
  @@index([phone, companyId])
}

enum LeadStatus {
  NEW
  CONTACTED
  PROPOSAL
  CLOSED
  LOST
}

// ─── Instâncias WhatsApp ──────────────────────────────────────────────────────

model WhatsappInstance {
  id           String         @id @default(cuid())
  instanceName String
  phone        String?
  status       InstanceStatus @default(DISCONNECTED)
  webhookUrl   String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId String

  messages Message[]

  @@index([companyId])
}

enum InstanceStatus {
  CONNECTED
  DISCONNECTED
  CONNECTING
}

// ─── Mensagens WhatsApp ───────────────────────────────────────────────────────

model Message {
  id           String      @id @default(cuid())
  externalId   String?     @unique
  phone        String
  body         String      @db.Text
  direction    MessageDir  @default(INBOUND)
  identifiedAs LeadStatus?
  processed    Boolean     @default(false)
  rawPayload   Json?
  receivedAt   DateTime    @default(now())

  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId String

  instance   WhatsappInstance? @relation(fields: [instanceId], references: [id])
  instanceId String?

  campaign   Campaign? @relation(fields: [campaignId], references: [id])
  campaignId String?

  lead   Lead?   @relation(fields: [leadId], references: [id])
  leadId String?

  @@index([companyId])
  @@index([phone, companyId])
  @@index([processed])
}

enum MessageDir {
  INBOUND
  OUTBOUND
}

// ─── Regras de Identificação ──────────────────────────────────────────────────

model KeywordRule {
  id        String     @id @default(cuid())
  keyword   String
  mapTo     LeadStatus
  priority  Int        @default(0)
  createdAt DateTime   @default(now())

  company   Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId String?

  campaign   Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  campaignId String?

  @@index([companyId])
  @@index([campaignId])
}

// ─── Configurações Globais ────────────────────────────────────────────────────

model Setting {
  key   String @id
  value String @db.Text
}

// ─── Chamados (Helpdesk) ──────────────────────────────────────────────────────

model Ticket {
  id          String         @id @default(cuid())
  title       String
  description String         @db.Text
  status      TicketStatus   @default(OPEN)
  priority    TicketPriority @default(MEDIUM)
  category    String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId String

  createdBy   User?   @relation("TicketCreatedBy", fields: [createdById], references: [id])
  createdById String?

  messages TicketMessage[]

  @@index([companyId])
  @@index([status])
}

model TicketMessage {
  id         String   @id @default(cuid())
  body       String   @db.Text
  isInternal Boolean  @default(false)
  authorName String
  authorRole String   @default("CLIENT")
  createdAt  DateTime @default(now())

  ticket   Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  ticketId String

  @@index([ticketId])
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}
