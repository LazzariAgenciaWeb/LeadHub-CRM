generator client {
  provider      = "prisma-client-js"
  output        = "../src/generated/prisma"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "linux-musl-arm64-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Usuários ─────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      UserRole @default(CLIENT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Assinatura exibida no início das mensagens WhatsApp enviadas pelo usuário
  whatsappSignature String?

  company   Company? @relation(fields: [companyId], references: [id])
  companyId String?

  ticketsCreated        Ticket[]               @relation("TicketCreatedBy")
  companyContact        CompanyContact?        @relation("ContactUser")
  setores               SetorUser[]
  conversationsAssigned Conversation[]         @relation("ConversationAssignee")
  googleConnections     UserGoogleConnection[]
  vaultChallenges       VaultEmailChallenge[]
  vaultTrustedSessions  VaultTrustedSession[]

  @@index([companyId])
}

// ─── 2FA por e-mail para revelar credenciais do cofre ─────────────────────────
// Cada vez que um usuário clica "Mostrar senha" e não tem trusted session
// ativa, geramos um código de 6 dígitos e enviamos para o e-mail dele.
// Após validar, criamos uma VaultTrustedSession de 15 min que dispensa
// novos códigos no intervalo.

model VaultEmailChallenge {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  codeHash     String // SHA-256 do código (não guardamos o texto claro)
  credentialId String? // credencial alvo (auditoria; não restringe a verify)

  attempts  Int      @default(0) // máx 5 tentativas por challenge
  used      Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId, expiresAt])
}

model VaultTrustedSession {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId, expiresAt])
}

// ─── Conexões pessoais com Google (Calendar e futuros serviços por usuário) ───
// Diferente de MarketingIntegration (por empresa, GA4/SC/GBP), aqui guardamos
// uma conexão OAuth por USUÁRIO. Cada atendente liga a própria conta Google
// para que o calendário pessoal apareça na vista "Meu Dia".

model UserGoogleConnection {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  service     String // "calendar" — extensível pra outros serviços pessoais
  googleEmail String?
  googleName  String?

  // OAuth tokens (criptografados via src/lib/crypto.ts — AES-256-GCM)
  accessTokenEnc  String?   @db.Text
  refreshTokenEnc String?   @db.Text
  tokenExpiresAt  DateTime?
  scopes          String[]  @default([])

  status     String    @default("ACTIVE") // ACTIVE | EXPIRED | DISCONNECTED | ERROR
  lastError  String?   @db.Text
  lastSyncAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, service])
  @@index([userId])
}

enum UserRole {
  SUPER_ADMIN
  ADMIN // admin da empresa (gerencia usuários, setores, config)
  CLIENT // agente/atendente — permissões controladas pelo setor
}

// ─── Empresas ─────────────────────────────────────────────────────────────────

model Company {
  id        String        @id @default(cuid())
  name      String
  slug      String        @unique
  segment   String?
  phone     String?
  email     String?
  website   String?
  logoUrl   String?
  status    CompanyStatus @default(ACTIVE)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  // Acesso ao sistema e módulos habilitados
  hasSystemAccess Boolean @default(false) // pode fazer login no portal?
  moduleWhatsapp  Boolean @default(false) // módulo WhatsApp
  moduleCrm       Boolean @default(true) // módulo CRM (padrão ligado)
  moduleTickets   Boolean @default(false) // módulo Chamados
  moduleAI        Boolean @default(false) // módulo Assistente IA

  // Hierarquia: empresa-pai gerencia sub-empresas (clientes da empresa)
  parentCompanyId String?
  parentCompany   Company?  @relation("SubCompanies", fields: [parentCompanyId], references: [id])
  subCompanies    Company[] @relation("SubCompanies")

  users                   User[]
  campaigns               Campaign[]
  leads                   Lead[]
  whatsappInstances       WhatsappInstance[]
  messages                Message[]
  keywordRules            KeywordRule[]
  tickets                 Ticket[]
  trackingLinks           TrackingLink[]
  pipelineStages          PipelineStageConfig[]
  contacts                CompanyContact[]
  setores                 Setor[]
  conversations           Conversation[]
  activities              Activity[]
  assets                  CompanyAsset[]
  credentialAccessLogs    CredentialAccessLog[]
  marketingIntegrations   MarketingIntegration[]
  analyticsSnapshots      AnalyticsSnapshot[]
  analyticsTopPages       AnalyticsTopPage[]
  analyticsTrafficSources AnalyticsTrafficSource[]
  analyticsGeoData        AnalyticsGeoData[]
  searchConsoleQueries    SearchConsoleQuery[]
  triggerOnly             Boolean                  @default(false)
  webhookToken            String?                  @unique // token público para receber leads via webhook

  @@index([parentCompanyId])
}

enum CompanyStatus {
  ACTIVE
  INACTIVE
}

// ─── Campanhas ────────────────────────────────────────────────────────────────

model Campaign {
  id          String         @id @default(cuid())
  name        String
  slug        String
  description String?
  source      CampaignSource @default(OTHER)
  status      CampaignStatus @default(ACTIVE)
  budget      Float?
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId String

  leads        Lead[]
  messages     Message[]
  links        TrackingLink[]
  keywordRules KeywordRule[]

  @@unique([companyId, slug])
  @@index([companyId])
}

enum CampaignSource {
  WHATSAPP
  INSTAGRAM
  FACEBOOK
  GOOGLE
  LINK
  OTHER
}

enum CampaignStatus {
  ACTIVE
  PAUSED
  FINISHED
}

// ─── Links de Rastreio ────────────────────────────────────────────────────────

model TrackingLink {
  id            String   @id @default(cuid())
  code          String   @unique
  label         String?
  destination   String
  destType      String   @default("url")
  clicks        Int      @default(0)
  ogTitle       String?
  ogDescription String?  @db.Text
  ogImage       String?
  createdAt     DateTime @default(now())

  campaign   Campaign? @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  campaignId String?

  company   Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId String?

  leads       Lead[]
  clickEvents ClickEvent[]

  @@index([campaignId])
  @@index([companyId])
}

model ClickEvent {
  id             String       @id @default(cuid())
  trackingLink   TrackingLink @relation(fields: [trackingLinkId], references: [id], onDelete: Cascade)
  trackingLinkId String
  targetUrl      String       @db.Text
  targetLabel    String?
  createdAt      DateTime     @default(now())

  @@index([trackingLinkId])
}

// ─── Leads ────────────────────────────────────────────────────────────────────

model Lead {
  id        String     @id @default(cuid())
  name      String?
  phone     String
  email     String?
  source    String?
  status    LeadStatus @default(NEW)
  notes     String?    @db.Text
  value     Float?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  // CRM Pipeline
  pipeline      String? // "PROSPECCAO" | "LEADS" | "OPORTUNIDADES"
  pipelineStage String? // nome da etapa configurável
  externalId    String? // ID externo (ex: id do Supabase BDR para evitar duplicatas)

  // Atendimento WhatsApp
  // @deprecated — espelho legacy de Conversation.status (mantido pra UI antiga via sync automático).
  // Leitura nova deve usar `lead.conversation.status`. Remover em migration futura.
  attendanceStatus String? // "WAITING" | "IN_PROGRESS" | "RESOLVED" | "SCHEDULED"
  expectedReturnAt DateTime? // previsão de retorno quando agendado

  // Integração ClickUp
  clickupTaskId String? // ID ou URL da tarefa no ClickUp

  // Visibilidade: isInternal=true → visível apenas ao SUPER_ADMIN (não aparece no portal do cliente)
  isInternal Boolean @default(false)

  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId String

  campaign   Campaign? @relation(fields: [campaignId], references: [id])
  campaignId String?

  trackingLink   TrackingLink? @relation(fields: [trackingLinkId], references: [id])
  trackingLinkId String?

  // Conversa unificada (uma conversa por telefone × empresa, criada no Sprint 1)
  conversation   Conversation? @relation(fields: [conversationId], references: [id])
  conversationId String?

  messages   Message[]
  comments   LeadComment[]
  activities Activity[]

  @@index([companyId])
  @@index([campaignId])
  @@index([phone, companyId])
  @@index([pipeline, companyId])
  @@index([externalId])
  @@index([conversationId])
}

enum LeadStatus {
  NEW
  CONTACTED
  PROPOSAL
  CLOSED
  LOST
}

// ─── Comentários de Lead ──────────────────────────────────────────────────────

model LeadComment {
  id         String   @id @default(cuid())
  body       String   @db.Text
  authorName String   @default("Usuário")
  createdAt  DateTime @default(now())

  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId String

  @@index([leadId])
}

// ─── Etapas de Pipeline Configuráveis ────────────────────────────────────────

model PipelineStageConfig {
  id       String  @id @default(cuid())
  pipeline String // "PROSPECCAO" | "LEADS" | "OPORTUNIDADES"
  name     String
  color    String  @default("#6366f1")
  order    Int     @default(0)
  isFinal  Boolean @default(false) // FECHADO / PERDIDO — etapas de encerramento

  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId String

  @@index([companyId, pipeline])
}

// ─── Contatos da Empresa (WhatsApp) ──────────────────────────────────────────

model CompanyContact {
  id        String   @id @default(cuid())
  name      String? // nome do contato / grupo
  phone     String // número (55...) ou group-id (@g.us)
  isGroup   Boolean  @default(false) // true = grupo do WhatsApp
  role      String   @default("CONTACT") // "CONTACT" | "DECISION_MAKER" | "TECHNICAL" | "FINANCIAL"
  hasAccess Boolean  @default(false) // acesso ao portal do cliente
  notes     String?
  createdAt DateTime @default(now())

  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId String

  // Quando hasAccess = true, pode ter um User vinculado (login no portal)
  user   User?   @relation("ContactUser", fields: [userId], references: [id])
  userId String? @unique

  @@unique([companyId, phone])
  @@index([companyId])
}

// ─── Instâncias WhatsApp ──────────────────────────────────────────────────────

model WhatsappInstance {
  id            String         @id @default(cuid())
  instanceName  String
  phone         String?
  status        InstanceStatus @default(DISCONNECTED)
  webhookUrl    String?
  instanceToken String? // token da instância na Evolution API (para auth em endpoints específicos)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId String

  messages Message[]
  setores  SetorInstance[]

  @@index([companyId])
}

enum InstanceStatus {
  CONNECTED
  DISCONNECTED
  CONNECTING
}

// ─── Mensagens WhatsApp ───────────────────────────────────────────────────────

model Message {
  id               String      @id @default(cuid())
  externalId       String?     @unique
  phone            String // telefone individual ou JID do grupo (@g.us)
  participantPhone String? // quem enviou dentro do grupo (preenchido só para mensagens de grupo)
  participantName  String? // nome do participante do grupo (pushName da Evolution API)
  body             String      @db.Text
  direction        MessageDir  @default(INBOUND)
  identifiedAs     LeadStatus?
  processed        Boolean     @default(false)
  rawPayload       Json?
  receivedAt       DateTime    @default(now())
  ack              Int? // ACK: 0=pending 1=server 2=delivered 3=read 4=played
  quotedId         String? // externalId da mensagem citada
  quotedBody       String?     @db.Text // snapshot do corpo da mensagem citada
  mediaBase64      String?     @db.Text // base64 da mídia (imagem/áudio) — vídeo/doc ignorados por tamanho
  mediaType        String? // MIME type: "image/jpeg", "audio/ogg; codecs=opus", etc.

  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId String

  instance   WhatsappInstance? @relation(fields: [instanceId], references: [id])
  instanceId String?

  campaign   Campaign? @relation(fields: [campaignId], references: [id])
  campaignId String?

  lead   Lead?   @relation(fields: [leadId], references: [id])
  leadId String?

  // Conversa unificada — populada pelo backfill (Sprint 1) e por toda mensagem nova (Sprint 2)
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  conversationId String?

  @@index([companyId])
  @@index([phone, companyId])
  @@index([processed])
  @@index([conversationId, receivedAt])
}

enum MessageDir {
  INBOUND
  OUTBOUND
}

// ─── Regras de Identificação ──────────────────────────────────────────────────

model KeywordRule {
  id        String     @id @default(cuid())
  keyword   String
  mapTo     LeadStatus
  priority  Int        @default(0)
  createdAt DateTime   @default(now())

  company   Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId String?

  campaign   Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  campaignId String?

  @@index([companyId])
  @@index([campaignId])
}

// ─── Configurações Globais ────────────────────────────────────────────────────

model Setting {
  key   String @id
  value String @db.Text
}

// ─── Conversation (CRM-style inbox) ──────────────────────────────────────────
// Uma Conversation envolve TODAS as mensagens trocadas com um telefone
// (individual ou grupo) dentro de uma empresa. Status, atribuição e SLA
// vivem aqui — não mais em Lead.attendanceStatus.

model Conversation {
  id String @id @default(cuid())

  // Identificação (telefone individual ou JID do grupo)
  phone   String
  isGroup Boolean @default(false)

  // Status e fluxo de atendimento
  status          ConversationStatus @default(OPEN)
  statusUpdatedAt DateTime           @default(now())

  // Atribuição
  assigneeId String? // User responsável (atendente que pegou)
  assignee   User?   @relation("ConversationAssignee", fields: [assigneeId], references: [id])
  setorId    String? // setor responsável (herdado da primeira instância que recebeu)
  setor      Setor?  @relation(fields: [setorId], references: [id])

  // Pré-cálculo da última mensagem (ordenação eficiente sem subquery)
  lastMessageAt        DateTime?
  lastMessageBody      String?     @db.Text
  lastMessageDirection MessageDir?
  unreadCount          Int         @default(0) // mensagens INBOUND não lidas pelo atendente

  // Retorno agendado
  scheduledReturnAt DateTime? // data/hora do retorno agendado (usado quando status=SCHEDULED)
  returnNote        String? // nota/motivo do agendamento

  // SLA
  firstResponseAt DateTime? // primeira resposta do atendente (calcula tempo de resposta)
  closedAt        DateTime?

  // Multi-tenant
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId String

  // Metadados
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relações inversas
  messages   Message[]
  notes      ConversationNote[]
  activities Activity[]
  leads      Lead[]

  @@unique([companyId, phone])
  @@index([companyId, status])
  @@index([companyId, lastMessageAt])
  @@index([assigneeId])
  @@index([setorId])
}

enum ConversationStatus {
  OPEN // 🆕 nova, aguardando ação (cyan)
  PENDING // 🔴 sem atendimento (passou SLA)
  IN_PROGRESS // 🟡 atendente atribuído e ativo
  WAITING_CUSTOMER // 🔵 respondemos, esperando cliente
  SCHEDULED // 🟣 standby — retorno agendado (usa Lead.expectedReturnAt como prazo)
  CLOSED // ⚪ finalizada
}

model ConversationNote {
  id         String   @id @default(cuid())
  body       String   @db.Text
  authorId   String?
  authorName String   @default("Sistema")
  // Tipo da nota — controla apresentação visual no chat:
  //   STANDARD  → amarelo/âmbar (anotação manual do atendente)
  //   SCHEDULED → roxo  (auto-gerada quando se agenda retorno)
  //   SYSTEM    → cinza (eventos automáticos diversos)
  type       String   @default("STANDARD")
  createdAt  DateTime @default(now())

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  conversationId String

  @@index([conversationId])
}

// ─── Activity (log universal) ─────────────────────────────────────────────────
// Registra eventos relevantes em Conversation, Lead ou Ticket. É o que
// alimenta a "linha do tempo" no modal e dashboards. NÃO duplica Message —
// mensagens vivem em Message; aqui ficam mudanças de estado, atribuições etc.

model Activity {
  id         String       @id @default(cuid())
  type       ActivityType
  body       String?      @db.Text
  meta       Json?
  authorId   String?
  authorName String?
  createdAt  DateTime     @default(now())

  // Pode pertencer a Conversation, Lead, Ticket (nullable — pelo menos um deve estar setado)
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  conversationId String?
  lead           Lead?         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId         String?
  ticket         Ticket?       @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  ticketId       String?

  // Multi-tenant
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId String

  @@index([conversationId, createdAt])
  @@index([leadId, createdAt])
  @@index([ticketId, createdAt])
  @@index([companyId, createdAt])
}

enum ActivityType {
  STATUS_CHANGED
  ASSIGNEE_CHANGED
  SECTOR_CHANGED
  STAGE_CHANGED
  PIPELINE_CHANGED
  VALUE_CHANGED
  NOTE_ADDED
  CLICKUP_LINKED
  TRACKING_LINK_SET
  LEAD_LINKED
  CONVERSATION_REOPENED
  CONVERSATION_CLOSED
  TRANSFERRED
  // Extensível conforme necessário
}

// ─── Chamados (Helpdesk) ──────────────────────────────────────────────────────

model Ticket {
  id            String         @id @default(cuid())
  title         String
  description   String         @db.Text
  status        TicketStatus   @default(OPEN)
  priority      TicketPriority @default(MEDIUM)
  category      String?
  phone         String? // telefone WhatsApp de origem (quando criado via WhatsApp)
  clickupTaskId String? // ID ou URL da tarefa no ClickUp
  ticketStage   String? // etapa configurável do kanban de chamados
  // Visibilidade: isInternal=true → visível apenas ao SUPER_ADMIN (não aparece no portal do cliente)
  isInternal    Boolean        @default(false)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId String

  createdBy   User?   @relation("TicketCreatedBy", fields: [createdById], references: [id])
  createdById String?

  // Setor responsável — quem não pertence ao setor não enxerga o chamado
  setor   Setor?  @relation(fields: [setorId], references: [id])
  setorId String?

  messages   TicketMessage[]
  activities Activity[]

  @@index([companyId])
  @@index([status])
  @@index([setorId])
}

model TicketMessage {
  id         String   @id @default(cuid())
  body       String   @db.Text
  isInternal Boolean  @default(false)
  authorName String
  authorRole String   @default("CLIENT")
  createdAt  DateTime @default(now())

  ticket   Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  ticketId String

  @@index([ticketId])
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// ─── Setores (controle de acesso interno por departamento) ────────────────────

model Setor {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId String

  // Permissões do setor
  canManageUsers     Boolean @default(false) // cadastrar/editar usuários
  canViewLeads       Boolean @default(true) // ver prospects/leads/oportunidades
  canCreateLeads     Boolean @default(false) // cadastrar/mover leads
  canViewTickets     Boolean @default(true) // ver chamados do setor
  canCreateTickets   Boolean @default(true) // abrir chamados
  canViewConfig      Boolean @default(false) // acessar configurações
  canUseAI           Boolean @default(false) // usar Assistente IA e sugestões
  canViewInbox       Boolean @default(true) // acessar caixa de entrada WhatsApp
  canSendMessages    Boolean @default(true) // enviar mensagens WhatsApp
  canViewCompanies   Boolean @default(false) // ver lista de empresas/clientes
  canCreateCompanies Boolean @default(false) // cadastrar novas empresas

  users         SetorUser[]
  instances     SetorInstance[]
  tickets       Ticket[]
  conversations Conversation[]

  @@index([companyId])
}

// Pivot: usuário ↔ setor (N:N — um usuário pode pertencer a vários setores)
model SetorUser {
  setorId String
  userId  String

  setor Setor @relation(fields: [setorId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([setorId, userId])
}

// Pivot: setor ↔ instância WhatsApp (N:N)
model SetorInstance {
  setorId    String
  instanceId String

  setor    Setor            @relation(fields: [setorId], references: [id], onDelete: Cascade)
  instance WhatsappInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  @@id([setorId, instanceId])
}

// ─── Cofre de credenciais ─────────────────────────────────────────────────────
//
// CompanyAsset é qualquer "recurso digital" que gerenciamos para o cliente:
// domínio, hospedagem, site, conta de e-mail, banco, repositório, etc.
// CompanyCredential guarda usuário+senha (criptografada) vinculados a um asset.
// CredentialAccessLog audita quem visualizou cada credencial.

model CompanyAsset {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  type       AssetType
  name       String
  url        String?
  host       String? // ex: "ftp.cliente.com.br", "mysql.cliente.com.br:3306"
  identifier String? // ex: nome do domínio "cliente.com.br", e-mail "vendas@x"
  provider   String? // ex: "Hostinger", "Cloudflare", "Google Workspace"
  status     AssetStatus @default(ACTIVE)
  expiresAt  DateTime? // renovação de domínio, validade de SSL, etc.
  notes      String?     @db.Text
  tags       String[]    @default([])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?

  credentials CompanyCredential[]

  @@index([companyId, type])
  @@index([companyId, expiresAt])
}

enum AssetType {
  DOMAIN
  HOSTING
  WEBSITE
  EMAIL_ACCOUNT
  DATABASE
  DNS_PROVIDER
  REPOSITORY
  SOCIAL_ACCOUNT
  ANALYTICS
  CLOUD_SERVICE
  OTHER
}

enum AssetStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  ARCHIVED
}

model CompanyCredential {
  id      String       @id @default(cuid())
  assetId String
  asset   CompanyAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  label             String // ex: "Admin WordPress", "FTP root", "cPanel"
  username          String?
  // Segredo criptografado (AES-256-GCM). Nunca armazenado em texto claro.
  // Formato no banco: base64(iv|authTag|ciphertext)
  passwordEncrypted String?
  url               String? // link de login direto
  totpSecret        String? // (opcional, criptografado tb) — backlog Fase 2
  notes             String? @db.Text

  lastRotatedAt    DateTime? // alerta para trocar senhas a cada N meses
  sharedWithClient Boolean   @default(false) // já foi compartilhada com o cliente?
  sharedAt         DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?

  accessLogs CredentialAccessLog[]

  @@index([assetId])
}

model CredentialAccessLog {
  id           String            @id @default(cuid())
  credentialId String
  credential   CompanyCredential @relation(fields: [credentialId], references: [id], onDelete: Cascade)

  // Denormalizado: facilita filtro "tudo que fulano viu na empresa X"
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  userId    String?
  userName  String? // snapshot (caso o user seja deletado)
  userRole  String?
  action    CredentialAction
  ipAddress String?
  userAgent String?
  createdAt DateTime         @default(now())

  @@index([credentialId, createdAt])
  @@index([companyId, createdAt])
}

enum CredentialAction {
  REVEAL // visualizou a senha
  COPY // copiou para o clipboard
  SHARE // compartilhou com o cliente (WhatsApp/email)
  EDIT // editou o registro
  CREATE
  DELETE
}

// ─── Integrações de Marketing ─────────────────────────────────────────────────
//
// MarketingIntegration: 1 conexão OAuth do cliente com um provedor (GA4, SC, GBP, Ads).
// Tokens são gravados criptografados (AES-256-GCM via src/lib/crypto.ts).
//
// Fontes de dados são puxadas via cron diário e gravadas em tabelas resumidas:
// AnalyticsSnapshot (1 linha/dia/empresa) — KPIs gerais
// AnalyticsTopPage / TrafficSource / GeoData — quebras dimensionais por dia
// SearchConsoleQuery — top queries por dia

model MarketingIntegration {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  provider     IntegrationProvider
  // Conta/propriedade conectada (ex: "properties/123456" pra GA4, "sc-domain:x.com" pra SC)
  accountId    String?
  accountLabel String? // nome amigável (ex: "azz.com.br")

  // OAuth tokens (criptografados)
  accessTokenEnc  String?   @db.Text
  refreshTokenEnc String?   @db.Text
  tokenExpiresAt  DateTime?
  scopes          String[]  @default([])

  // Identidade do usuário Google que autorizou
  googleEmail String?
  googleName  String?

  status         IntegrationStatus @default(ACTIVE)
  lastSyncAt     DateTime?
  lastSyncStatus String? // "ok" | "error: ..."
  lastError      String?           @db.Text

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?

  @@unique([companyId, provider, accountId])
  @@index([companyId])
  @@index([status, lastSyncAt])
}

enum IntegrationProvider {
  GA4 // Google Analytics 4
  SEARCH_CONSOLE // Google Search Console
  BUSINESS_PROFILE // Google Meu Negócio (GBP)
  GOOGLE_ADS
  META_ADS
}

enum IntegrationStatus {
  ACTIVE
  EXPIRED // refresh token inválido / revogado
  ERROR // falha repetida no sync
  DISCONNECTED // usuário desconectou manualmente
}

model AnalyticsSnapshot {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  date      DateTime @db.Date
  source    String // "ga4" | "pixel" (futuramente)

  sessions        Int    @default(0)
  users           Int    @default(0)
  newUsers        Int    @default(0)
  pageviews       Int    @default(0)
  conversions     Int    @default(0)
  bounceRate      Float? // 0..1
  avgSessionSec   Float?
  engagedSessions Int?   @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, date, source])
  @@index([companyId, date])
}

model AnalyticsTopPage {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  date      DateTime @db.Date
  source    String // "ga4"

  pagePath   String
  pageTitle  String?
  views      Int     @default(0)
  users      Int     @default(0)
  avgTimeSec Float?

  @@unique([companyId, date, source, pagePath])
  @@index([companyId, date])
}

model AnalyticsTrafficSource {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  date      DateTime @db.Date
  source    String // "ga4"

  // Dados brutos do GA4
  rawSource String // ex: "google", "instagram.com", "chatgpt.com"
  rawMedium String // ex: "organic", "referral", "cpc"

  // Categoria classificada pela nossa lógica (src/lib/traffic-classifier.ts)
  bucket String // "AI" | "ORGANIC_SEARCH" | "PAID_SEARCH" | "INSTAGRAM" | ...

  sessions    Int @default(0)
  users       Int @default(0)
  conversions Int @default(0)

  @@unique([companyId, date, source, rawSource, rawMedium])
  @@index([companyId, date, bucket])
}

model AnalyticsGeoData {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  date      DateTime @db.Date
  source    String // "ga4"

  countryCode String? // "BR", "US"
  countryName String?
  region      String? // estado / província
  city        String?

  sessions Int @default(0)
  users    Int @default(0)

  @@unique([companyId, date, source, countryCode, region, city])
  @@index([companyId, date])
}

model SearchConsoleQuery {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  date      DateTime @db.Date

  query   String
  page    String?
  country String? // "bra"
  device  String? // "MOBILE" | "DESKTOP" | "TABLET"

  clicks      Int
  impressions Int
  ctr         Float // 0..1
  position    Float // posição média

  @@unique([companyId, date, query, page, country, device])
  @@index([companyId, date])
  @@index([companyId, query])
}
